# RedCache environment (infrastructure defaults).
#
# NOTE: Site mode, favorites URL, and active categories are configured in the
# app's first-run onboarding UI and stored in the database — you normally do
# NOT need to edit them here. XHS_SITE_MODE / XHS_FAVORITES_URL below are only
# used to seed a brand-new database before onboarding.

APP_ENV=local
DATABASE_URL=sqlite:///./data/xhs_curator.db
OBSIDIAN_VAULT_PATH=../exports/obsidian
BACKUP_ROOT=../data/backups
SAMPLE_POSTS_PATH=./data/sample_posts.json

# Seed values for a fresh database (onboarding overrides these in the UI).
XHS_SITE_MODE=rednote
XHS_FAVORITES_URL=

# Browser / crawler infrastructure.
XHS_PLAYWRIGHT_PROFILE_ROOT=../data/playwright-profile
XHS_USE_SYSTEM_CHROME=false
CRAWLER_SCROLL_STEPS=8
CRAWLER_SCROLL_PAUSE_MS=1200
CRAWLER_PAGE_LOAD_TIMEOUT_MS=20000

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Daily Review scheduling.
EXPORT_DAILY_REVIEW_ENABLED=true
REVIEW_TIMEZONE=America/Los_Angeles
REVIEW_BASELINE_LOCAL=2026-07-09T22:30:00
DAILY_FETCH_ENABLED=true
DAILY_FETCH_LOCAL_TIME=22:30
